# Copy this file to .env and fill in values for your AI stack.
# Required before -server, -ask, or -reindex-embeddings.

# Active stack: ollama | lmstudio | openai | claude
AI_DEFAULT_STACK=ollama

# --- Ollama (local) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- LM Studio (local, OpenAI-compatible) ---
AI_LMSTUDIO_BASE_URL=http://localhost:1234/v1

# --- OpenAI (cloud) ---
OPENAI_API_KEY=sk-your-openai-key

# --- Claude + Voyage (cloud) ---
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
VOYAGE_API_KEY=pa-your-voyage-key
